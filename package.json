{
  "name": "eclipse-local",
  "private": true,
  "version": "0.1.0",
  "description": "Lokale Berechnung und 3D-Visualisierung von Sonnenfinsternissen",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/MichaelHein65/Sonnenfinsternis.git"
  },
