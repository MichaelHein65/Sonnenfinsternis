  },
  "devDependencies": {
    "@types/d3-geo": "^3.1.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/geojson": "^7946.0.16",
    "@types/three": "^0.179.0",
    "@types/topojson-client": "^3.1.5",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "^5.8.3",
